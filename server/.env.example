# Core runtime
NODE_ENV=development
PORT=10000

# Database
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>

# Auth
JWT_SECRET=replace-with-32-plus-char-secret
SESSION_SECRET=replace-with-strong-session-secret

# App URLs
CLIENT_URL=http://localhost:3000
SOCKET_CORS_ORIGIN=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
FROM_EMAIL=no-reply@yourdomain.com

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
STRIPE_BILLING_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx

# Optional services
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:10000/api/auth/google/callback

# Booking SQL (new subsystem)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
BOOKING_SQL_ENABLED=false
BOOKING_SQL_LOG_LEVEL=info

SENTRY_DSN=your-server-sentry-dsn
