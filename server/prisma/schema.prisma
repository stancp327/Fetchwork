generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  pending_payment
  held
  confirmed
  in_progress
  completed
  cancelled_by_client
  cancelled_by_freelancer
  no_show_client
  no_show_freelancer
  disputed
  resolved
}

enum ActorType {
  client
  freelancer
  admin
  system
}

model Booking {
  id                  String        @id @default(uuid()) @db.Uuid
  bookingRef          String        @unique
  clientId            String
  freelancerId        String
  serviceOfferingId   String?       @db.Uuid
  policySnapshotJson  Json
  pricingSnapshotJson Json
  currentState        BookingStatus @default(pending_payment)
  notes               String?
  createdAt           DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime      @updatedAt @db.Timestamptz(6)

  occurrences      BookingOccurrence[]
  auditEvents      AuditEvent[]
  chargeRecords    ChargeRecord[]
  recurringSeries  RecurringSeries?

  @@index([clientId, createdAt(sort: Desc)])
  @@index([freelancerId, createdAt(sort: Desc)])
}

model BookingOccurrence {
  id                  String        @id @default(uuid()) @db.Uuid
  bookingId           String        @db.Uuid
  occurrenceNo        Int           @default(1)
  clientId            String
  freelancerId        String
  startAtUtc          DateTime      @db.Timestamptz(6)
  endAtUtc            DateTime      @db.Timestamptz(6)
  timezone            String
  localStartWallclock String
  localEndWallclock   String
  status              BookingStatus @default(held)
  seriesId            String?       @db.Uuid
  skipped             Boolean       @default(false)
  createdAt           DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime      @updatedAt @db.Timestamptz(6)

  booking          Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  series           RecurringSeries?   @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  auditEvents      AuditEvent[]
  chargeRecords    ChargeRecord[]
  attendanceRecord AttendanceRecord?

  @@unique([bookingId, occurrenceNo])
  @@index([freelancerId, startAtUtc])
  @@index([clientId, startAtUtc])
  @@index([status, startAtUtc])
  @@index([seriesId, startAtUtc])
}

// ═══════════════════════════════════════════════════════════════════════════════
// RECURRING SERIES
// Weekly/biweekly/monthly recurring booking schedules
// ═══════════════════════════════════════════════════════════════════════════════

model RecurringSeries {
  id               String    @id @default(uuid()) @db.Uuid
  bookingId        String    @unique @db.Uuid

  frequency        String    // weekly | biweekly | monthly | custom
  intervalDays     Int       // 7=weekly, 14=biweekly, ~30=monthly, custom

  startDate        String    // YYYY-MM-DD (first occurrence)
  endDate          String?   // YYYY-MM-DD (last possible, null=indefinite)
  maxOccurrences   Int?      // cap on total occurrences (null=no cap)

  startTime        String    // HH:MM wallclock
  endTime          String    // HH:MM wallclock
  timezone         String

  status           String    @default("active") // active | paused | cancelled | completed
  cancelledAt      DateTime? @db.Timestamptz(6)
  cancelledFromDate String?  // YYYY-MM-DD — occurrences on/after this date are cancelled

  generatedThrough String?   // YYYY-MM-DD — last date occurrences were generated up to
  generatedCount   Int       @default(0)

  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @db.Timestamptz(6)

  booking          Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  occurrences      BookingOccurrence[]

  @@map("recurring_series")
  @@index([status, startDate])
}

model AuditEvent {
  id           BigInt    @id @default(autoincrement())
  bookingId    String    @db.Uuid
  occurrenceId String?   @db.Uuid
  actorType    ActorType
  actorId      String?
  eventType    String
  payloadJson  Json
  payloadHash  String
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)

  booking    Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  occurrence BookingOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@index([occurrenceId, createdAt])
  @@index([eventType, createdAt])
}

model IdempotencyKey {
  id             BigInt   @id @default(autoincrement())
  idempotencyKey String
  route          String
  actorId        String
  requestHash    String
  responseJson   Json
  statusCode     Int
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  @@unique([idempotencyKey, route, actorId])
  @@index([createdAt])
}

model ChargeRecord {
  id                    String   @id @default(uuid()) @db.Uuid
  bookingId             String   @db.Uuid
  occurrenceId          String?  @db.Uuid
  stripePaymentIntentId String?  @unique
  stripeChargeId        String?  @unique
  amountCents           Int
  currency              String   @default("usd")
  platformFeeCents      Int      @default(0)
  payoutAmountCents     Int      @default(0)
  state                 String   @default("none")
  idempotencyKey        String?
  metadataJson          Json     @default("{}")
  createdAt             DateTime @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @db.Timestamptz(6)

  booking    Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  occurrence BookingOccurrence? @relation(fields: [occurrenceId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt(sort: Desc)])
  @@index([occurrenceId, createdAt(sort: Desc)])
}

model AttendanceRecord {
  id                    String    @id @default(uuid()) @db.Uuid
  occurrenceId          String    @unique @db.Uuid
  status                String    @default("not_started")
  clientCheckinAt       DateTime? @db.Timestamptz(6)
  freelancerCheckinAt   DateTime? @db.Timestamptz(6)
  clientCheckoutAt      DateTime? @db.Timestamptz(6)
  freelancerCheckoutAt  DateTime? @db.Timestamptz(6)
  clientCheckinMeta     Json?
  freelancerCheckinMeta Json?
  disputeFlag           Boolean   @default(false)
  adminAdjustmentJson   Json?
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(6)

  occurrence BookingOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// HYBRID AVAILABILITY SYSTEM
// Freelancer global defaults + per-service overrides + date exceptions
// ═══════════════════════════════════════════════════════════════════════════════

model FreelancerAvailability {
  id                    String   @id @default(uuid()) @db.Uuid
  freelancerId          String   @unique
  timezone              String   @default("America/Los_Angeles")
  defaultSlotDuration   Int      @default(60)  // minutes
  bufferTime            Int      @default(0)   // minutes between slots
  defaultCapacity       Int      @default(1)   // 1=individual, >1=group
  minNoticeHours        Int      @default(24)  // can't book < X hours from now
  maxAdvanceBookingDays Int      @default(60)  // can't book > X days out
  isActive              Boolean  @default(true)
  
  // Weekly schedule: JSON array of { dayOfWeek: 0-6, windows: [{startTime, endTime}] }
  weeklyScheduleJson    Json     @default("[]")
  
  createdAt             DateTime @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @db.Timestamptz(6)

  serviceOverrides ServiceAvailabilityOverride[]
  exceptions       AvailabilityException[]

  @@index([freelancerId])
}

model ServiceAvailabilityOverride {
  id                    String   @id @default(uuid()) @db.Uuid
  freelancerAvailId     String   @db.Uuid
  serviceId             String   // MongoDB ObjectId reference
  
  // Override fields (null = use freelancer default)
  timezone              String?
  slotDuration          Int?     // minutes
  bufferTime            Int?     // minutes
  capacity              Int?     // max per slot
  minNoticeHours        Int?
  maxAdvanceBookingDays Int?
  
  // Override weekly schedule (null = use freelancer default)
  weeklyScheduleJson    Json?
  
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @db.Timestamptz(6)

  freelancerAvailability FreelancerAvailability @relation(fields: [freelancerAvailId], references: [id], onDelete: Cascade)

  @@unique([freelancerAvailId, serviceId])
  @@index([serviceId])
}

model AvailabilityException {
  id                String   @id @default(uuid()) @db.Uuid
  freelancerAvailId String   @db.Uuid
  serviceId         String?  // null = applies to all services
  
  date              String   // "YYYY-MM-DD" in freelancer's local timezone
  unavailable       Boolean  @default(true)  // true = day off, false = custom hours
  
  // Custom windows for this date (only used when unavailable=false)
  windowsJson       Json?    // [{startTime, endTime}]
  
  reason            String?  // "Holiday", "Vacation", etc.
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)

  freelancerAvailability FreelancerAvailability @relation(fields: [freelancerAvailId], references: [id], onDelete: Cascade)

  @@unique([freelancerAvailId, serviceId, date])
  @@index([freelancerAvailId, date])
  @@index([serviceId, date])
}

// ═══════════════════════════════════════════════════════════════════════════════
// REMINDER SYSTEM
// Scheduled notifications for bookings (email, push, SMS)
// ═══════════════════════════════════════════════════════════════════════════════

enum ReminderChannel {
  email
  push
  sms
}

enum ReminderStatus {
  scheduled
  sent
  failed
  cancelled
}

model BookingReminder {
  id            String         @id @default(uuid()) @db.Uuid
  bookingId     String         @db.Uuid
  occurrenceId  String         @db.Uuid
  recipientId   String         // User ID (client or freelancer)
  recipientRole String         // "client" or "freelancer"
  channel       ReminderChannel
  
  reminderType  String         // "24h_before", "1h_before", "15m_before", "followup"
  scheduledFor  DateTime       @db.Timestamptz(6)
  
  status        ReminderStatus @default(scheduled)
  sentAt        DateTime?      @db.Timestamptz(6)
  failReason    String?
  
  // Content snapshot (so we don't need to re-fetch booking details)
  contentJson   Json           @default("{}")
  
  createdAt     DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @db.Timestamptz(6)

  @@index([status, scheduledFor])
  @@index([bookingId])
  @@index([occurrenceId])
  @@index([recipientId, status])
}

// ═══════════════════════════════════════════════════════════════════════════════
// GROUP BOOKINGS + WAITLIST
// Supports classes, group sessions, and waitlist auto-promotion
// ═══════════════════════════════════════════════════════════════════════════════

enum WaitlistStatus {
  waiting
  promoted
  expired
  cancelled
}

model GroupBookingSlot {
  id                String   @id @default(uuid()) @db.Uuid
  serviceId         String   // MongoDB service reference
  freelancerId      String
  
  // Slot timing
  date              String   // "YYYY-MM-DD"
  startTime         String   // "HH:mm"
  endTime           String   // "HH:mm"
  startAtUtc        DateTime @db.Timestamptz(6)
  endAtUtc          DateTime @db.Timestamptz(6)
  timezone          String
  
  // Capacity
  totalCapacity     Int      @default(10)
  bookedCount       Int      @default(0)
  
  // Pricing (can differ from 1:1)
  pricePerPersonCents Int    @default(0)
  
  // Status
  isActive          Boolean  @default(true)
  isFull            Boolean  @default(false)
  
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)

  participants      GroupParticipant[]
  waitlistEntries   WaitlistEntry[]

  @@unique([serviceId, date, startTime])
  @@index([freelancerId, date])
  @@index([serviceId, startAtUtc])
  @@index([isFull, startAtUtc])
}

enum ParticipantStatus {
  held
  confirmed
  cancelled
  no_show
}

model GroupParticipant {
  id                String            @id @default(uuid()) @db.Uuid
  slotId            String            @db.Uuid
  clientId          String
  
  // Booking reference (links to main Booking if needed)
  bookingId         String?           @db.Uuid
  
  seatCount         Int               @default(1)
  status            ParticipantStatus @default(held)
  
  // Hold expiry for pending payments
  holdExpiresAt     DateTime?         @db.Timestamptz(6)
  
  // Payment tracking
  paidAmountCents   Int               @default(0)
  
  createdAt         DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @db.Timestamptz(6)

  slot              GroupBookingSlot  @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@unique([slotId, clientId])
  @@index([clientId, status])
  @@index([slotId, status])
  @@index([holdExpiresAt])
}

model WaitlistEntry {
  id                String         @id @default(uuid()) @db.Uuid
  slotId            String         @db.Uuid
  clientId          String
  
  seatCount         Int            @default(1)
  status            WaitlistStatus @default(waiting)
  position          Int            // Queue position (1 = first in line)
  
  // When they joined the waitlist
  joinedAt          DateTime       @default(now()) @db.Timestamptz(6)
  
  // When they were promoted (if applicable)
  promotedAt        DateTime?      @db.Timestamptz(6)
  
  // Expiry for promotion offer
  promotionExpiresAt DateTime?     @db.Timestamptz(6)
  
  // Contact preference for notification
  notifyEmail       Boolean        @default(true)
  notifyPush        Boolean        @default(true)
  
  createdAt         DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @db.Timestamptz(6)

  slot              GroupBookingSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@unique([slotId, clientId])
  @@index([slotId, status, position])
  @@index([clientId, status])
}
