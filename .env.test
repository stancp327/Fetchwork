# ── FetchWork Test Environment Template ─────────────────────────────────────
# Copy this to .env.test.local and fill in any overrides.
# These values are used by Jest integration tests and Playwright E2E.
# NEVER use real credentials here.

NODE_ENV=test

# Auth
JWT_SECRET=test-secret-key-for-jest-minimum-32-chars-long
SESSION_SECRET=test-session-secret-minimum-32-chars
ADMIN_EMAILS=admin@fetchwork.test

# MongoDB — integration tests use mongodb-memory-server (auto-assigned URI)
# Unit tests don't need a real URI at all.
MONGO_URI=mongodb://localhost/fetchwork_test

# Stripe — use Stripe test mode keys; webhook secret from Stripe Dashboard (test)
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_TEST_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_TEST_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_TEST_WEBHOOK_SECRET
STRIPE_BILLING_WEBHOOK_SECRET=whsec_REPLACE_WITH_BILLING_TEST_SECRET
PLATFORM_FEE_PERCENT=10

# Email — point to Ethereal or stub; integration tests mock the service
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=test@ethereal.email
SMTP_PASS=testpassword
FROM_EMAIL=noreply@fetchwork.test

# Google OAuth — use test credentials; auth tests mock passport entirely
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# App URLs
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000

# Playwright E2E target
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Disable rate limiting in tests
RATE_LIMIT_SKIP=true
